# TLMA 代理网关配置 — 构建时打入镜像，无需进入容器修改
# 填入 API Key，然后 docker build

# Proxy service
PROXY_API_KEY=

# Vision service (Aliyun Bailian Coding Plan)
VISION_API_KEY=
VISION_BASE_URL=https://coding.dashscope.aliyuncs.com
VISION_MODEL=kimi-k2.5
VISION_TIMEOUT=30

# Decision engine (DeepSeek)
DECISION_API_KEY=
DECISION_BASE_URL=https://api.deepseek.com/v1
DECISION_MODEL=deepseek-chat
DECISION_TIMEOUT=5
