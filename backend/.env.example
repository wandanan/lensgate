# TLMA 代理网关配置 — 构建时打入镜像，无需进入容器修改
# 填入 API Key，然后 docker build

# Proxy service
# 本项目网关 API Key。留空 = 不校验（本地/内网部署）。填值 = 客户端 x-api-key 必须匹配。
PROXY_API_KEY=

# Vision service
# 识图服务。走 OpenAI Chat Completions 协议 (/v1/chat/completions)。
# 换任意兼容该协议的视觉服务只需改下面 4 个字段，框架不绑定特定厂商。
# 下方默认值为阿里云百炼 Coding Plan + Qwen 3.7 Plus。
# 识图 API Key。
VISION_API_KEY=
# 识图 API 地址。换其他服务时改这里即可。
VISION_BASE_URL=https://coding.dashscope.aliyuncs.com
# 识图模型。默认使用千问版本 qwen3.7-plus。
# 请填写服务商实际支持的模型名；也可填任意 OpenAI-compatible 视觉模型的真实模型名。
VISION_MODEL=qwen3.7-plus
# 识图超时（秒）。双图对比需要较长时间，设 180 留足余量。
VISION_TIMEOUT=180

# Decision engine (DeepSeek)
# 决策引擎：判断用户想看哪张图、单图还是对比。纯文本调用，轻量快速。
# 同样走 OpenAI Chat Completions 协议，可换任意兼容服务。
DECISION_API_KEY=
# 决策 API 地址，不用改。
DECISION_BASE_URL=https://api.deepseek.com/v1
# 决策模型，纯文本快模型即可，不用换。
DECISION_MODEL=deepseek-chat
# 决策超时（秒）。决策是轻量文本请求，5s 足够。
DECISION_TIMEOUT=5
